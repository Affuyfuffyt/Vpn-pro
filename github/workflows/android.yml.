name: Build V2Ray VPN APK

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    # 1. تحميل الكود الخاص بك
    - name: Checkout code
      uses: actions/checkout@v3

    # 2. تجهيز بيئة الجافا
    - name: Set up JDK 11
      uses: actions/setup-java@v3
      with:
        java-version: '11'
        distribution: 'temurin'
        cache: gradle

    # 3. إعطاء صلاحية التنفيذ لملف gradlew (إن وجد) أو استخدام gradle مباشرة
    - name: Make gradlew executable
      run: chmod +x gradlew || true

    # 4. بناء ملف الـ APK (Debug)
    - name: Build with Gradle
      run: gradle assembleDebug --no-daemon

    # 5. رفع ملف الـ APK الناتج لكي تحمله أنت
    - name: Upload APK
      uses: actions/upload-artifact@v4
      with:
        name: vpn-app-debug
        path: app/build/outputs/apk/debug/app-debug.apk
